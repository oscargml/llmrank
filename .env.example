# Copy this file to .env.local for local development.
# Do not commit .env.local. Add these same names in Vercel Project Settings -> Environment Variables.

# Required for real LLM analysis. Without it, LLMRank returns demo/default scores.
ANTHROPIC_API_KEY=

# Optional. Defaults to claude-sonnet-4-20250514.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional integrations. Without these, LLMRank returns demo/default values for those sections.
PAGE_SPEED_API_KEY=
SERP_API_KEY=
WAPPALYZER_API_KEY=
SEMRUSH_API_KEY=
